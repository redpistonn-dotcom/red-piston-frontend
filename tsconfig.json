{
  "compilerOptions": {
    /* Build target */
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    /* Module resolution — "bundler" matches Vite's behaviour */
    "module": "ESNext",
    "moduleResolution": "bundler",

    /* Allow imports that keep .js extensions to resolve to .ts files.
       Requires noEmit:true — Vite handles actual output, not tsc. */
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* JSX — use React 17+ automatic transform (no import React needed) */
    "jsx": "react-jsx",

    /* Incremental migration settings:
       allowJs     — JS files compile alongside TS during migration
       checkJs     — false: JS files are trusted, only TS files are checked
       strict      — false: start lenient, enable once all files are typed
       skipLibCheck — skips checking .d.ts files (faster, avoids @types conflicts) */
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "skipLibCheck": true,

    /* Stricter checks we CAN enable now (safe regardless of strict:false) */
    "noImplicitAny": false,
    "strictNullChecks": false,

    /* Path aliases — add when needed */
    "paths": {}
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
